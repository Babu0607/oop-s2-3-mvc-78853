@model IEnumerable<VgcCollege.Web.Models.CourseEnrolment>

@{
    ViewData["Title"] = "My Courses";
}

<h1 class="mb-4">My Enrolled Courses</h1>

@if (Model != null && Model.Any())
{
    <div class="row">
        @foreach (var enrolment in Model)
        {
            <div class="col-md-6 mb-3">
                <div class="card h-100">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">@enrolment.Course?.Name</h5>
                    </div>
                    <div class="card-body">
                        <p><strong>Branch:</strong> @enrolment.Course?.Branch?.Name</p>
                        <p><strong>Duration:</strong> @enrolment.Course?.StartDate.ToShortDateString() - @enrolment.Course?.EndDate.ToShortDateString()</p>
                        <p><strong>Status:</strong> <span class="badge bg-success">@enrolment.Status</span></p>
                    </div>
                    <div class="card-footer">
                        <a href="/Student/CourseDetails?courseId=@enrolment.CourseId" class="btn btn-primary btn-sm">View Details</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info">You are not enrolled in any courses yet.</div>
}

<div class="mt-3">
    <a href="/Student" class="btn btn-secondary">Back to Dashboard</a>
</div>
