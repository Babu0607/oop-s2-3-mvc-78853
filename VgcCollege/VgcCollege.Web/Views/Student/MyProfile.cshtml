@model VgcCollege.Web.Models.StudentProfile

@{
    ViewData["Title"] = "Student Dashboard";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-dark text-white py-3 text-center">
                    <i class="bi bi-person-badge-fill fs-1"></i>
                    <h4 class="mt-2 mb-0">@Model.Name</h4>
                    <p class="small text-light">@Model.StudentNumber</p>
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <strong>Email:</strong>
                            <span class="text-muted small">@Model.Email</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <strong>Status:</strong>
                            <span class="badge bg-success">Active Student</span>
                        </li>
                    </ul>
                </div>
            </div>
            
            <div class="d-grid gap-2">
                <a asp-action="AvailableCourses" class="btn btn-primary shadow-sm">
                    <i class="bi bi-search"></i> Browse More Courses
                </a>
            </div>
        </div>

        <div class="col-md-8">
            <h3 class="mb-4">My Enrolled Courses</h3>

            @if (ViewBag.MyCourses != null && ((List<VgcCollege.Web.Models.CourseEnrolment>)ViewBag.MyCourses).Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle bg-white shadow-sm rounded">
                        <thead class="table-light">
                            <tr>
                                <th>Course Name</th>
                                <th>Campus</th>
                                <th>Start Date</th>
                                <th class="text-center">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var enrollment in (List<VgcCollege.Web.Models.CourseEnrolment>)ViewBag.MyCourses)
                            {
                                <tr>
                                    <td class="fw-bold">@enrollment.Course?.Name</td>
                                    <td>
                                        <i class="bi bi-geo-alt-fill text-danger"></i> 
                                        @(enrollment.Course?.Branch?.Name ?? "Main Campus")
                                    </td>
                                    <td>@enrollment.Course?.StartDate.ToShortDateString()</td>
                                    <td class="text-center">
                                        <span class="badge rounded-pill bg-light text-dark border">Confirmed</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info border-0 shadow-sm p-5 text-center">
                    <i class="bi bi-journal-x fs-1"></i>
                    <h4 class="mt-3">No active enrollments</h4>
                    <p class="mb-4 text-muted">You haven't joined any courses yet. Get started today!</p>
                    <a asp-action="AvailableCourses" class="btn btn-outline-primary">Browse Course Catalog</a>
                </div>
            }
        </div>
    </div>
</div>