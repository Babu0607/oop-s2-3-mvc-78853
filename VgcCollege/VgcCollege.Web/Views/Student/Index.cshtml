@{
    ViewData["Title"] = "Student Dashboard";
    var student = ViewBag.Student as VgcCollege.Web.Models.StudentProfile;
    var enrolments = ViewBag.Enrolments as List<VgcCollege.Web.Models.CourseEnrolment>;
}

<div class="container">
    <h1 class="mb-4">Student Dashboard</h1>
    
    <div class="row">
        <div class="col-md-4">
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">My Profile</h5>
                </div>
                <div class="card-body">
                    <h5>Welcome, @student?.Name!</h5>
                    <p class="text-muted">Student Number: @student?.StudentNumber</p>
                    <hr />
                    <p><strong>Email:</strong> @student?.Email</p>
                    <p><strong>Phone:</strong> @student?.Phone</p>
                </div>
            </div>
        </div>
        
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">My Active Courses</h5>
                </div>
                <div class="card-body">
                    @if (enrolments != null && enrolments.Any())
                    {
                        <div class="list-group">
                            @foreach (var enrolment in enrolments)
                            {
                                <a href="/Student/CourseDetails?courseId=@enrolment.CourseId" class="list-group-item list-group-item-action">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="mb-1">@enrolment.Course?.Name</h6>
                                            <small class="text-muted">@enrolment.Course?.Branch?.Name</small>
                                        </div>
                                        <span class="badge bg-primary rounded-pill">Active</span>
                                    </div>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">You are not enrolled in any courses yet.</div>
                    }
                </div>
            </div>
        </div>
    </div>
    
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">Quick Links</h5>
                </div>
                <div class="card-body text-center">
                    <a href="/Student/MyCourses" class="btn btn-outline-primary m-2">All Courses</a>
                    <a href="/Student/MyGrades" class="btn btn-outline-success m-2">My Grades</a>
                    <a href="/Student/MyAttendance" class="btn btn-outline-warning m-2">My Attendance</a>
                </div>
            </div>
        </div>
    </div>
</div>
