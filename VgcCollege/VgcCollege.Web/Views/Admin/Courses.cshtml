@model IEnumerable<VgcCollege.Web.Models.Course>

@{
    ViewData["Title"] = "Manage Courses";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Courses</h1>
    <a href="/Admin/CreateCourse" class="btn btn-primary">
        <i class="fas fa-plus"></i> Add New Course
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <table class="table table-striped table-hover">
            <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Branch</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var course in Model)
            {
                <tr>
                    <td>@course.Id</td>
                    <td>@course.Name</td>
                    <td>@course.Branch?.Name</td>
                    <td>@course.StartDate.ToShortDateString()</td>
                    <td>@course.EndDate.ToShortDateString()</td>
                    <td>
                        <a href="/Admin/EditCourse/@course.Id" class="btn btn-sm btn-warning">
                            <i class="fas fa-edit"></i> Edit
                        </a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>