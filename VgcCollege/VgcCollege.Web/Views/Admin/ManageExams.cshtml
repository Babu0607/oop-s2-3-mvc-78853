@model IEnumerable<VgcCollege.Web.Models.Exam>

@{
    ViewData["Title"] = "Manage Exams";
}

<h1 class="mb-4">Manage Exam Results Release</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Exam Title</th>
                    <th>Course</th>
                    <th>Date</th>
                    <th>Max Score</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var exam in Model)
                {
                    <tr>
                        <td>@exam.Title</td>
                        <td>@exam.Course?.Name</td>
                        <td>@exam.Date.ToShortDateString()</td>
                        <td>@exam.MaxScore</td>
                        <td>
                            @if (exam.ResultsReleased)
                            {
                                <span class="badge bg-success">Released</span>
                            }
                            else
                            {
                                <span class="badge bg-warning">Provisional</span>
                            }
                        </td>
                        <td>
                            <form asp-action="ToggleResultRelease" method="post" style="display:inline">
                                <input type="hidden" name="examId" value="@exam.Id" />
                                <button type="submit" class="btn btn-sm @(exam.ResultsReleased ? "btn-warning" : "btn-success")">
                                    @(exam.ResultsReleased ? "Make Provisional" : "Release Results")
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3">
    <div class="alert alert-info">
        <strong>Note:</strong> When results are "Released", students can see their grades. 
        When "Provisional", students cannot see their grades.
    </div>
</div>