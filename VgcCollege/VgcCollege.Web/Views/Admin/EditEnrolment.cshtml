@model VgcCollege.Web.Models.CourseEnrolment

@{
    ViewData["Title"] = "Edit Enrolment";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h3>Edit Enrolment</h3>
            </div>
            <div class="card-body">
                <form asp-action="EditEnrolment" method="post">
                    <input type="hidden" asp-for="Id" />
                    
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="mb-3">
                        <label asp-for="StudentProfileId" class="form-label">Student</label>
                        <select asp-for="StudentProfileId" class="form-control" asp-items="@(ViewBag.Students)">
                            <option value="">-- Select Student --</option>
                        </select>
                        <span asp-validation-for="StudentProfileId" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="CourseId" class="form-label">Course</label>
                        <select asp-for="CourseId" class="form-control" asp-items="@(ViewBag.Courses)">
                            <option value="">-- Select Course --</option>
                        </select>
                        <span asp-validation-for="CourseId" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="EnrolDate" class="form-label">Enrolment Date</label>
                        <input asp-for="EnrolDate" type="date" class="form-control" />
                        <span asp-validation-for="EnrolDate" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Status" class="form-label">Status</label>
                        <select asp-for="Status" class="form-control">
                            <option value="Active">Active</option>
                            <option value="Completed">Completed</option>
                            <option value="Dropped">Dropped</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                        <a href="/Admin/Enrolments" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>