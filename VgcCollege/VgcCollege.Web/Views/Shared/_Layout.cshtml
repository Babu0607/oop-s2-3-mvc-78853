<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Vgc College</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="navbar">
        <a href="/" class="brand">Vgc College</a>
        
        @if (User.Identity.IsAuthenticated)
        {
            @if (User.IsInRole("Admin"))
            {
                <a href="/Admin/Branches"><i class="fas fa-building"></i> Branches</a>
                <a href="/Admin/Courses"><i class="fas fa-book"></i> Courses</a>
                <a href="/Admin/Enrolments"><i class="fas fa-user-graduate"></i> Enrolments</a>
                <a href="/Admin/ManageExams"><i class="fas fa-chart-line"></i> Exams</a>
                <a href="/Admin/Students"><i class="fas fa-users"></i> Students</a>
                <a href="/Admin/Faculty"><i class="fas fa-chalkboard-user"></i> Faculty</a>
            }
            
            @if (User.IsInRole("Faculty"))
            {
                <a href="/Faculty/Index"><i class="fas fa-list"></i> My Courses</a>
                <a href="/Faculty/Gradebook"><i class="fas fa-gradebook"></i> Gradebook</a>
                <a href="/Faculty/Attendance"><i class="fas fa-calendar-check"></i> Attendance</a>
            }
            
            @if (User.IsInRole("Student"))
            {
                <a href="/Student/Index"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
                <a href="/Student/MyCourses"><i class="fas fa-book-open"></i> My Courses</a>
                <a href="/Student/MyGrades"><i class="fas fa-chart-line"></i> My Grades</a>
                <a href="/Student/MyAttendance"><i class="fas fa-calendar-alt"></i> Attendance</a>
            }
            
            <div class="nav-right">
                <a href="#"><i class="fas fa-user-circle"></i> @User.Identity.Name</a>
                <a href="/Identity/Account/Logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
            </div>
        }
        else
        {
            <div class="nav-right">
                <a href="/Identity/Account/Login"><i class="fas fa-sign-in-alt"></i> Login</a>
                <a href="/Identity/Account/Register"><i class="fas fa-user-plus"></i> Register</a>
            </div>
        }
    </div>

    <div class="container">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                <i class="fas fa-check-circle"></i> @TempData["Success"]
            </div>
        }
        
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
            </div>
        }
        
        <main>
            @RenderBody()
        </main>
    </div>

    <div class="footer">
        &copy; @DateTime.Now.Year - Vgc College Management System
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>