@using VgcCollege.Web.Models
@model IEnumerable<Course>
@{
    ViewData["Title"] = "Manage Courses";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h1>@ViewData["Title"]</h1>
        <a asp-action="CreateCourse" class="btn btn-success">Add New Course</a>
    </div>

    <table class="table table-hover mt-4">
        <thead class="table-dark">
        <tr>
            <th>Course Name</th>
            <th>Branch (Campus)</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><strong>@item.Name</strong></td>
                <td>@(item.Branch?.Name ?? "No Branch Assigned")</td>
                <td>@item.StartDate.ToShortDateString()</td>
                <td>@item.EndDate.ToShortDateString()</td>
                <td>
                    <a class="btn btn-sm btn-outline-info" asp-action="EditCourse" asp-route-id="@item.Id">Edit</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="DeleteCourse" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>