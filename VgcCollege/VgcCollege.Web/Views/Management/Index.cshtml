@{
    ViewData["Title"] = "Management Dashboard";
}

<div class="text-center mt-5">
    <h1 class="display-4">College Administration</h1>
    <p class="lead">Select a category below to manage college data.</p>
</div>

<div class="row mt-5">
    <div class="col-md-4">
        <div class="card shadow-sm mb-4">
            <div class="card-body text-center">
                <h5 class="card-title">Branches</h5>
                <p class="card-text">Manage campus locations and addresses.</p>
                <a asp-action="Branches" class="btn btn-primary">Go to Branches</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm mb-4">
            <div class="card-body text-center">
                <h5 class="card-title">Roles</h5>
                <p class="card-text">Manage system permissions and access levels.</p>
                <a asp-action="Roles" class="btn btn-secondary">Manage Roles</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm mb-4">
            <div class="card-body text-center">
                <h5 class="card-title">Courses</h5>
                <p class="card-text">Set up and edit college courses.</p>
                <a asp-action="Courses" class="btn btn-success">Manage Courses</a>
            </div>
        </div>
    </div>
</div>