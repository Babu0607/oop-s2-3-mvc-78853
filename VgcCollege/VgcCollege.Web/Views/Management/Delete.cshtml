@using VgcCollege.Web.Models
@model Course

@* @model VgcCollege.Web.Models.Course *@

@{
    ViewData["Title"] = "Delete Course";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Confirm Deletion</h4>
                </div>
                <div class="card-body">
                    <p class="lead">Are you sure you want to delete this course?</p>
                    <div class="bg-light p-3 rounded mb-4">
                        <dl class="row mb-0">
                            <dt class="col-sm-4">Course Name:</dt>
                            <dd class="col-sm-8">@Model.Name</dd>

                            <dt class="col-sm-4">Campus:</dt>
                            <dd class="col-sm-8">@(Model.Branch?.Name ?? "General")</dd>

                            <dt class="col-sm-4">Duration:</dt>
                            <dd class="col-sm-8">
                                @Model.StartDate.ToShortDateString() - @Model.EndDate.ToShortDateString()
                            </dd>
                        </dl>
                    </div>

                    <div class="alert alert-warning">
                        <strong>Warning:</strong> Deleting this course may affect enrolled students and existing gradebooks.
                    </div>

                    <form asp-action="DeleteCourse">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-between">
                            <a asp-action="Courses" class="btn btn-outline-secondary">Cancel, Keep it</a>
                            <button type="submit" class="btn btn-danger px-4">Yes, Delete Course</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>